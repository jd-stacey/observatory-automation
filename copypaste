def test_status_checks(driver: DomeDriver) -> bool:
    """Run all read-only status checks. Returns True if all pass."""
    section("SECTION 1: STATUS CHECKS (read-only, no movement)")

    all_passed = True

    step("1.1  Connection check")
    connected = driver.is_connected()
    print(f"  is_connected() : {connected}")
    if not connected:
        print("  FAILED: Not connected - cannot continue")
        return False
    print("  PASSED")

    step("1.2  Raw state")
    try:
        state = driver.get_state()
        print(f"  Raw state dict : {state}")
        print("  PASSED")
    except DomeError as e:
        print(f"  FAILED: {e}")
        all_passed = False

    step("1.3  Individual state methods")
    try:
        print(f"  get_left_state()  : {driver.get_left_state()}")
        print(f"  get_right_state() : {driver.get_right_state()}")
        print(f"  is_open()         : {driver.is_open()}")
        print(f"  is_closed()       : {driver.is_closed()}")
        print(f"  is_moving()       : {driver.is_moving()}")
        print("  PASSED")
    except DomeError as e:
        print(f"  FAILED: {e}")
        all_passed = False

    step("1.4  Full dome info dict")
    try:
        info = driver.get_dome_info()
        for k, v in info.items():
            print(f"  {k:<22} : {v}")
        print("  PASSED")
    except Exception as e:
        print(f"  FAILED: {e}")
        all_passed = False

    step("1.5  Disconnect and reconnect cycle")
    try:
        config = driver.config
        print("  Disconnecting...")
        driver.disconnect()
        print(f"  is_connected() after disconnect : {driver.is_connected()}")
        print("  Reconnecting...")
        reconnected = driver.connect(config)
        print(f"  Reconnected : {reconnected}")
        print(f"  is_connected() after reconnect : {driver.is_connected()}")
        if reconnected:
            print("  PASSED")
        else:
            print("  FAILED: Could not reconnect")
            all_passed = False
    except Exception as e:
        print(f"  FAILED: {e}")
        all_passed = False

    return all_passed


def test_left_panel(driver: DomeDriver) -> bool:
    """Test left panel open and close. Returns True if all pass."""
    section("SECTION 2: LEFT PANEL TESTS")

    print("\n  Current dome state:")
    print_state(driver)

    print(f"\n  This will open and close the LEFT panel only.")
    print(f"  Right panel will remain unchanged.")
    if not ask_proceed("Proceed with left panel tests?"):
        print("  Skipped by user.")
        return True     # skipped not failed

    all_passed = True

    # --- Open left ---
    step("2.1  Open left panel")
    print("\n  Sending open left command...")
    try:
        success = driver._send_command("/dome/left/true")
        if not success:
            print("  Command returned failure")
            all_passed = False
            if not ask_continue_after_failure():
                return False
        else:
            print("  Command accepted, polling for state change...")
            reached = wait_with_progress(
                driver,
                target_left=DomeDriver.STATE_OPEN,
                target_right=driver.get_right_state(),
                timeout=driver.timeout_move
            )
            if reached:
                print("  PASSED: Left panel opened")
            else:
                print("  FAILED: Left panel did not reach open state")
                all_passed = False
                if not ask_continue_after_failure():
                    return False
    except Exception as e:
        print(f"  ERROR: {e}")
        all_passed = False
        if not ask_continue_after_failure():
            return False

    print("\n  Current dome state:")
    print_state(driver)

    # --- Close left ---
    step("2.2  Close left panel")
    if not ask_proceed("Proceed with closing left panel?"):
        print("  Skipped by user.")
    else:
        print("\n  Sending close left command...")
        try:
            success = driver._send_command("/dome/left/false")
            if not success:
                print("  Command returned failure")
                all_passed = False
                if not ask_continue_after_failure():
                    return False
            else:
                print("  Command accepted, polling for state change...")
                reached = wait_with_progress(
                    driver,
                    target_left=DomeDriver.STATE_CLOSED,
                    target_right=driver.get_right_state(),
                    timeout=driver.timeout_move
                )
                if reached:
                    print("  PASSED: Left panel closed")
                else:
                    print("  FAILED: Left panel did not reach closed state")
                    all_passed = False
                    if not ask_continue_after_failure():
                        return False
        except Exception as e:
            print(f"  ERROR: {e}")
            all_passed = False
            if not ask_continue_after_failure():
                return False

    print("\n  Current dome state:")
    print_state(driver)

    return all_passed


