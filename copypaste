class NightModal(tk.Toplevel):
    def __init__(self, parent, mode: str, on_confirm):
        super().__init__(parent)
        self.title("")
        self.configure(bg=SURFACE)
        self.resizable(False, False)
        self.grab_set()
        self._on_confirm = on_confirm
        self._mode = mode
 
        # Centre on parent
        self.update_idletasks()
        px = parent.winfo_rootx() + parent.winfo_width()//2
        py = parent.winfo_rooty() + parent.winfo_height()//2
        self.geometry(f"340x280+{px-170}+{py-140}")
 
        # Border frame
        outer = tk.Frame(self, bg=ACCENT, padx=1, pady=1)
        outer.pack(fill="both", expand=True)
        inner = tk.Frame(outer, bg=SURFACE)
        inner.pack(fill="both", expand=True)
 
        # Title
        c = GREEN if mode == "start" else RED
        label = "◆  START NIGHT" if mode == "start" else "◆  END NIGHT"
        tk.Label(inner, text=label, font=("Consolas", 11, "bold"),
                 fg=c, bg=SURFACE).pack(pady=(14, 4))
 
        desc = ("Select operations to perform at session start:" if mode == "start"
                else "Select shutdown operations to perform:")
        tk.Label(inner, text=desc, font=("Consolas", 8),
                 fg=TEXT_SEC, bg=SURFACE, wraplength=290).pack(pady=(0, 10))
 
        # Checkboxes
        opts = ([("Open dome panels", "dome"),
                 ("Open telescope covers", "covers"),
                 ("Enable telescope motors", "motors")]
                if mode == "start" else
                [("Park telescope", "park"),
                 ("Close telescope covers", "covers"),
                 ("Close dome panels", "dome")])
 
        self._vars = {}
        opt_frame = tk.Frame(inner, bg=SURFACE)
        opt_frame.pack(fill="x", padx=24)
        for label_text, key in opts:
            var = tk.BooleanVar(value=True)
            self._vars[key] = var
            row = tk.Frame(opt_frame, bg=SURFACE)
            row.pack(fill="x", pady=3)
            cb = tk.Checkbutton(row, text=label_text.upper(),
                                variable=var,
                                font=("Consolas", 8, "bold"),
                                fg=TEXT_PRI, bg=SURFACE,
                                selectcolor=PANEL,
                                activebackground=SURFACE,
                                activeforeground=ACCENT,
                                highlightthickness=0)
            cb.pack(side="left")
 
        # Buttons
        btn_row = tk.Frame(inner, bg=SURFACE)
        btn_row.pack(pady=14)
 
        cancel = tk.Label(btn_row, text="CANCEL", font=("Consolas", 8, "bold"),
                          fg=TEXT_SEC, bg=SURFACE, cursor="hand2", padx=12, pady=5)
        cancel.pack(side="left", padx=6)
        cancel.bind("<Button-1>", lambda e: self.destroy())
        cancel.bind("<Enter>", lambda e: cancel.config(fg=TEXT_PRI))
        cancel.bind("<Leave>", lambda e: cancel.config(fg=TEXT_SEC))
 
        exec_lbl = "EXECUTE" if mode == "start" else "SHUTDOWN"
        exec_btn = tk.Label(btn_row, text=exec_lbl, font=("Consolas", 8, "bold"),
                            fg=c, bg=PANEL, cursor="hand2", padx=12, pady=5,
                            highlightbackground=c, highlightthickness=1)
        exec_btn.pack(side="left", padx=6)
        exec_btn.bind("<Button-1>", self._execute)
        exec_btn.bind("<Enter>", lambda e: exec_btn.config(bg=SURFACE))
        exec_btn.bind("<Leave>", lambda e: exec_btn.config(bg=PANEL))
 
    def _execute(self, e=None):
        opts = {k: v.get() for k, v in self._vars.items()}
        self.destroy()
        self._on_confirm(self._mode, opts)
 
 
