class LogConsole(tk.Frame):
    COLOURS = {"INFO": ACCENT, "WARN": AMBER, "ERROR": RED, "OK": GREEN, "SYS": TEXT_SEC}
 
    def __init__(self, parent, **kw):
        super().__init__(parent, bg=BG, **kw)
        self._text = tk.Text(self, bg=BG, fg=TEXT_PRI,
                             font=("Consolas", 8),
                             state="disabled", wrap="word",
                             relief="flat", highlightthickness=0,
                             padx=8, pady=6, height=8)
        scroll = tk.Scrollbar(self, command=self._text.yview, bg=SURFACE,
                              troughcolor=BG, highlightthickness=0)
        self._text.config(yscrollcommand=scroll.set)
        scroll.pack(side="right", fill="y")
        self._text.pack(side="left", fill="both", expand=True)
 
        for tag, color in self.COLOURS.items():
            self._text.tag_config(f"lvl_{tag}", foreground=color)
        self._text.tag_config("ts", foreground="#3D4A57")
 
    def log(self, level: str, msg: str):
        ts = datetime.now(timezone.utc).strftime("%H:%M:%S")
        self._text.config(state="normal")
        self._text.insert("end", ts + "  ", "ts")
        self._text.insert("end", f"[{level:4s}]  ", f"lvl_{level}")
        self._text.insert("end", msg + "\n")
        self._text.see("end")
        self._text.config(state="disabled")
 
    def clear(self):
        self._text.config(state="normal")
        self._text.delete("1.0", "end")
        self._text.config(state="disabled")
 
 
