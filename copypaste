def draw_telescope(canvas, cx, cy, color):
    """Draw telescope icon centred at cx, cy."""
    canvas.delete("all")
    c = color
    # tripod legs
    canvas.create_line(cx, cy+8, cx-12, cy+22, fill=c, width=2, capstyle="round")
    canvas.create_line(cx, cy+8, cx+12, cy+22, fill=c, width=2, capstyle="round")
    canvas.create_line(cx, cy+8, cx, cy+22,    fill=c, width=2, capstyle="round")
    canvas.create_line(cx-14, cy+22, cx+14, cy+22, fill=c, width=2, capstyle="round")
    # tube
    canvas.create_rectangle(cx-16, cy-10, cx+16, cy+8, outline=c, width=2)
    # objective lens cap (circle at left end)
    canvas.create_oval(cx-20, cy-6, cx-14, cy+4, outline=c, width=2)
    # eyepiece stub (right end)
    canvas.create_rectangle(cx+16, cy-4, cx+22, cy+2, outline=c, width=2)
    # finder scope (small tube on top)
    canvas.create_rectangle(cx-10, cy-16, cx+8, cy-10, outline=c, width=1)
    canvas.create_line(cx-10, cy-13, cx-16, cy-8, fill=c, width=1)
    canvas.create_line(cx+8,  cy-13, cx+14, cy-8, fill=c, width=1)
 
 
def draw_covers(canvas, cx, cy, color):
    canvas.delete("all")
    c = color
    r = 20
    canvas.create_oval(cx-r, cy-r, cx+r, cy+r, outline=c, width=2)
    # left panel
    canvas.create_arc(cx-r, cy-r, cx+r, cy+r, start=90, extent=180,
                      outline=c, fill=PANEL, width=2, style="chord")
    # right panel
    canvas.create_arc(cx-r, cy-r, cx+r, cy+r, start=270, extent=180,
                      outline=c, fill=PANEL, width=2, style="chord")
    # centre divider
    canvas.create_line(cx, cy-r, cx, cy+r, fill=c, width=2)
    # hinge dots
    canvas.create_oval(cx-3, cy-3, cx+3, cy+3, outline=c, width=2)
    # bracket lines (L/R)
    for dx in (-r-6, r+6):
        canvas.create_line(cx+dx, cy-6, cx+dx, cy+6, fill=c, width=2)
        canvas.create_line(cx+dx-3, cy-6, cx+dx+3, cy-6, fill=c, width=1)
        canvas.create_line(cx+dx-3, cy+6, cx+dx+3, cy+6, fill=c, width=1)
 
 
def draw_dome(canvas, cx, cy, color):
    canvas.delete("all")
    c = color
    # dome arc
    canvas.create_arc(cx-22, cy-14, cx+22, cy+18, start=0, extent=180,
                      outline=c, fill=PANEL, width=2, style="arc")
    # walls
    canvas.create_rectangle(cx-22, cy+2, cx+22, cy+12, outline=c, width=2)
    # door slit
    canvas.create_rectangle(cx-7, cy+2, cx+7, cy+12, outline=c, width=1)
    # base
    canvas.create_rectangle(cx-26, cy+12, cx+26, cy+16, outline=c, width=1)
 
 
def draw_rotator(canvas, cx, cy, color, accent=ACCENT):
    canvas.delete("all")
    c = color
    ac = accent if color != TEXT_SEC else "#4A5568"
    # outer ring
    canvas.create_oval(cx-20, cy-20, cx+20, cy+20, outline=c, width=2)
    # inner ring
    canvas.create_oval(cx-9,  cy-9,  cx+9,  cy+9,  outline=c, width=2)
    # centre dot
    canvas.create_oval(cx-3, cy-3, cx+3, cy+3, fill=c, outline=c)
    # rotation arrows (left arc)
    canvas.create_arc(cx-26, cy-14, cx-6, cy+14, start=210, extent=120,
                      outline=ac, width=2, style="arc")
    # arrowhead left
    canvas.create_line(cx-26, cy+2, cx-22, cy-4, fill=ac, width=2)
    canvas.create_line(cx-26, cy+2, cx-20, cy+4, fill=ac, width=2)
    # rotation arrows (right arc)
    canvas.create_arc(cx+6, cy-14, cx+26, cy+14, start=330, extent=120,
                      outline=ac, width=2, style="arc")
    # arrowhead right
    canvas.create_line(cx+26, cy+2, cx+22, cy-4, fill=ac, width=2)
    canvas.create_line(cx+26, cy+2, cx+20, cy+4, fill=ac, width=2)
 
 
