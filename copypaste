# Configuration - change this to test a different dome
# ---------------------------------------------------------------------------
TEST_DOME_KEY = "dome_t2"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def separator(char="-", width=60):
    print(char * width)

def section(title: str):
    print()
    separator("=")
    print(f"  {title}")
    separator("=")

def step(title: str):
    print()
    separator()
    print(f"  {title}")
    separator()

def ask_proceed(prompt: str = "Proceed?") -> bool:
    """Ask user yes/no. Returns True if yes."""
    while True:
        response = input(f"\n  {prompt} [y/n]: ").strip().lower()
        if response in ('y', 'yes'):
            return True
        if response in ('n', 'no'):
            return False
        print("  Please enter y or n.")

def ask_continue_after_failure() -> bool:
    """Ask user whether to continue after a test failure."""
    print("\n  !! TEST STEP FAILED !!")
    return ask_proceed("Continue to next test anyway?")

def print_state(driver: DomeDriver):
    """Print current dome state in a readable format."""
    try:
        state = driver.get_state()
        print(f"  Left panel  : {state.get('left',  '???')}")
        print(f"  Right panel : {state.get('right', '???')}")
        print(f"  Closed      : {state.get('closed', '???')}")
        last = "".join(state.get('lastChars', []))[-10:]
        if last:
            print(f"  Last chars  : {last}")
    except DomeError as e:
        print(f"  ERROR reading state: {e}")

def wait_with_progress(driver: DomeDriver, target_left: str, target_right: str,
                       timeout: int, poll_interval: float = 2.0) -> bool:
    """
    Poll dome state with printed progress until target reached or timeout.
    Returns True if target state reached.
    """
    print(f"\n  Waiting for: left={target_left}, right={target_right}")
    print(f"  Timeout: {timeout}s  |  Polling every {poll_interval}s")
    print()
    start = time.time()
    left = right = "unknown"
    while time.time() - start < timeout:
        try:
            state = driver.get_state()
            left  = state.get('left',  'unknown')
            right = state.get('right', 'unknown')
            elapsed = int(time.time() - start)
            print(f"  [{elapsed:>3}s]  Left: {left:<16}  Right: {right}", end='\r')
            if left == target_left and right == target_right:
                print()  # clear the \r line
                print(f"\n  Target state reached after {elapsed}s")
                return True
        except DomeError as e:
            print(f"\n  ERROR polling state: {e}")
        time.sleep(poll_interval)
    print()  # clear the \r line
    print(f"\n  TIMEOUT after {timeout}s  |  Last: left={left}, right={right}")
    return False

def run_test(label: str, fn, *args) -> bool:
    """
    Run a single test function, print result, return success bool.
    fn should return True on success.
    """
    print(f"\n  Running: {label}...")
    try:
        result = fn(*args)
        if result:
            print(f"  PASSED: {label}")
        else:
            print(f"  FAILED: {label}")
        return result
    except Exception as e:
        print(f"  ERROR: {label} raised exception: {e}")
        return False

