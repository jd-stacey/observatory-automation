    # ── Logging ────────────────────────────────────────────────────────────────
 
    def log(self, level: str, msg: str):
        self.root.after(0, lambda: self.console.log(level, msg))
 
    # ── State colour helper ────────────────────────────────────────────────────
 
    @staticmethod
    def _sc(s: str) -> str:
        if not s or s in ("—", "UNKNOWN", "OFFLINE", "N/A"): return TEXT_SEC
        if s in ("OPEN",):       return AMBER
        if s in ("CLOSED", "PARKED"): return GREEN
        if s in ("OPENING", "CLOSING", "PARKING", "MOVING"): return AMBER
        if s in ("TRACKING", "ONLINE", "SLEWING"): return GREEN
        return TEXT_PRI
 
    # ── HTTP helpers (ALPACA) ─────────────────────────────────────────────────
 
    def _alpaca_get(self, address, device_type, device_number, prop, timeout=5):
        try:
            r = requests.get(
                f"http://{address}/api/v1/{device_type}/{device_number}/{prop}",
                timeout=timeout)
            if r.status_code == 200:
                return r.json().get("Value"), None
            return None, f"HTTP {r.status_code}"
        except Exception as e:
            return None, str(e)
 
    def _alpaca_connected(self, address, device_type, device_number) -> bool:
        val, _ = self._alpaca_get(address, device_type, device_number, "connected")
        return bool(val)
 
    # ── Connect All ───────────────────────────────────────────────────────────
 
    def _connect_all(self):
        self.conn_btn.config(text="CONNECTING...", fg=AMBER)
        self.log("SYS", "Initiating connection to all devices...")
        self.log("INFO", "Ensure Autoslew and ASCOM Remote are running")
 
        def worker():
            for dev in ("telescope", "cover", "dome", "rotator"):
                self._connect_device(dev)
                time.sleep(0.3)
            self.root.after(0, lambda: self.conn_btn.config(
                text="⏻  CONNECT ALL", fg=ACCENT))
            self.log("OK", "Connection sequence complete")
 
        threading.Thread(target=worker, daemon=True).start()
 
    # ── Individual Connect ────────────────────────────────────────────────────
 
    def _connect_device(self, device: str):
        threading.Thread(
            target=self._connect_worker, args=(device,), daemon=True).start()
 
    def _connect_worker(self, device: str):
        names = {"telescope": "Telescope", "cover": "Covers",
                 "dome": "Dome", "rotator": "Rotator"}
        name  = names.get(device, device)
        card_map = {"telescope": self.tel_card, "cover": self.cov_card,
                    "dome": self.dome_card, "rotator": self.rot_card}
        card = card_map[device]
 
        self.root.after(0, lambda: card.set_lamp("connecting"))
        self.root.after(0, lambda: card.badge.set("CONNECTING", AMBER))
        self.log("SYS", f"Connecting to {name}...")
 
        ok = False
        try:
            if device == "telescope":
                ok = self._do_connect_telescope()
            elif device == "cover":
                ok = self._do_connect_cover()
            elif device == "dome":
                ok = self._do_connect_dome()
            elif device == "rotator":
                ok = self._do_connect_rotator()
        except Exception as e:
            self.log("ERROR", f"{name}: {e}")
 
        state = "connected" if ok else "disconnected"
        self.root.after(0, lambda: card.set_lamp(state))
        if not ok:
            self.root.after(0, lambda: card.badge.set("FAILED", RED))
            self.log("ERROR", f"{name} connection failed")
        else:
            self.log("OK", f"{name} connected")
 
    def _do_connect_telescope(self) -> bool:
        cfg = DEVICE_CONFIGS["telescope"]
        addr, dn = cfg["address"], cfg["device_number"]
 
        if not self._alpaca_connected(addr, "telescope", dn):
            self.log("WARN", "Telescope ALPACA reports not connected")
            self.root.after(0, lambda: self.tel_card.badge.set("NOT CONNECTED", RED))
            return False
 
        ra,    _ = self._alpaca_get(addr, "telescope", dn, "rightascension")
        dec,   _ = self._alpaca_get(addr, "telescope", dn, "declination")
        alt,   _ = self._alpaca_get(addr, "telescope", dn, "altitude")
        az,    _ = self._alpaca_get(addr, "telescope", dn, "azimuth")
        parked,_ = self._alpaca_get(addr, "telescope", dn, "atpark")
        slewing,_= self._alpaca_get(addr, "telescope", dn, "slewing")
 
        def _fmt_ra(v):
            if v is None: return "—"
            h = int(v); m = int((v-h)*60); s = ((v-h)*60-m)*60
            return f"{h:02d}h {m:02d}m {s:04.1f}s"
 
        def _fmt_dec(v):
            if v is None: return "—"
            sign = "+" if v >= 0 else "-"; v = abs(v)
            d = int(v); m = int((v-d)*60); s = ((v-d)*60-m)*60
            return f"{sign}{d:02d}° {m:02d}′ {s:04.1f}″"
 
        status = ("PARKED" if parked else "SLEWING" if slewing else "TRACKING")
 
        def _upd():
            self.tel_card.badge.set(status, self._sc(status))
            self._tel_ra.set(_fmt_ra(ra))
            self._tel_dec.set(_fmt_dec(dec))
            self._tel_alt.set(f"{alt:.2f}°" if alt is not None else "—")
            self._tel_az.set( f"{az:.2f}°"  if az  is not None else "—")
            self._tel_status.set(status, self._sc(status))
            self._park_btn.set_enabled(not bool(parked))
            self._abort_btn.set_enabled(True)
 
        self.root.after(0, _upd)
 
        # Start live poll
        self._start_tel_poll()
        return True
 
    def _do_connect_cover(self) -> bool:
        cfg = DEVICE_CONFIGS["cover"]
        addr, dn = cfg["address"], cfg["device_number"]
 
        connected = self._alpaca_connected(addr, "covercalibrator", dn)
        if not connected:
            self.root.after(0, lambda: self.cov_card.badge.set("NOT CONNECTED", RED))
            return False
 
        state_map = {0: "UNKNOWN", 1: "CLOSED", 2: "MOVING", 3: "OPEN", 4: "ERROR"}
        val, _ = self._alpaca_get(addr, "covercalibrator", dn, "coverstate")
        state = state_map.get(val, "UNKNOWN")
 
        def _upd():
            self.cov_card.badge.set(state, self._sc(state))
            self._cov_state.set(state, self._sc(state))
            self._cov_moving.set("NO")
            self._cov_open_btn.set_enabled(True)
            self._cov_close_btn.set_enabled(True)
 
        self.root.after(0, _upd)
        self._start_cover_poll()
        return True
 
    def _do_connect_dome(self) -> bool:
        if not DOME_DRIVER:
            # fall back to raw HTTP
            try:
                r = requests.get(
                    f"http://{DEVICE_CONFIGS['dome']['host']}:{DEVICE_CONFIGS['dome']['port']}/dome/state",
                    timeout=3)
                if r.status_code != 200:
                    return False
                data = r.json()
                left  = (data.get("left",  "unknown")).upper()
                right = (data.get("right", "unknown")).upper()
                overall = "CLOSED" if data.get("closed") else "OPEN"
 
                def _upd():
                    self.dome_card.badge.set(overall, self._sc(overall))
                    self._dome_left.set(left, self._sc(left))
                    self._dome_right.set(right, self._sc(right))
                    self._dome_overall.set(overall, self._sc(overall))
                    for b in (self._dome_open_btn, self._dome_close_btn, self._dome_abort_btn):
                        b.set_enabled(True)
 
                self.root.after(0, _upd)
                self._start_dome_poll()
                return True
            except Exception as e:
                self.log("ERROR", f"Dome HTTP: {e}")
                return False
 
        # Use DomeDriver
        self.dome_driver = DomeDriver()
        if not self.dome_driver.connect(DEVICE_CONFIGS["dome"]):
            self.dome_driver = None
            return False
 
        info = self.dome_driver.get_dome_info()
        left    = str(info.get("left",  "unknown")).upper()
        right   = str(info.get("right", "unknown")).upper()
        overall = "CLOSED" if info.get("closed") else "OPEN"
 
        def _upd():
            self.dome_card.badge.set(overall, self._sc(overall))
            self._dome_left.set(left, self._sc(left))
            self._dome_right.set(right, self._sc(right))
            self._dome_overall.set(overall, self._sc(overall))
            for b in (self._dome_open_btn, self._dome_close_btn, self._dome_abort_btn):
                b.set_enabled(True)
 
        self.root.after(0, _upd)
        self._start_dome_poll()
        return True
 
    def _do_connect_rotator(self) -> bool:
        cfg = DEVICE_CONFIGS["rotator"]
        addr, dn = cfg["address"], cfg["device_number"]
 
        connected = self._alpaca_connected(addr, "rotator", dn)
        if not connected:
            self.root.after(0, lambda: self.rot_card.badge.set("NOT CONNECTED", RED))
            return False
 
        pos,     _ = self._alpaca_get(addr, "rotator", dn, "position")
        moving,  _ = self._alpaca_get(addr, "rotator", dn, "ismoving")
        lim = cfg.get("mechanical_limits", {})
        lim_str = f"{lim.get('min_deg','?')}°–{lim.get('max_deg','?')}°" if lim else "N/A"
 
        def _upd():
            self.rot_card.badge.set("ONLINE", GREEN)
            self._rot_pos.set(f"{pos:.2f}°" if pos is not None else "—")
            self._rot_moving.set("YES" if moving else "NO",
                                 AMBER if moving else TEXT_SEC)
            self._rot_mech.set(lim_str)
 
        self.root.after(0, _upd)
        self._start_rotator_poll()
        return True
 
    # ── Polling loops ─────────────────────────────────────────────────────────
 
    def _start_tel_poll(self):
        def poll():
            cfg = DEVICE_CONFIGS["telescope"]
            addr, dn = cfg["address"], cfg["device_number"]
            if not self._alpaca_connected(addr, "telescope", dn):
                self.root.after(0, lambda: self.tel_card.set_lamp("disconnected"))
                return
            ra,    _ = self._alpaca_get(addr, "telescope", dn, "rightascension")
            dec,   _ = self._alpaca_get(addr, "telescope", dn, "declination")
            alt,   _ = self._alpaca_get(addr, "telescope", dn, "altitude")
            az,    _ = self._alpaca_get(addr, "telescope", dn, "azimuth")
            parked,_ = self._alpaca_get(addr, "telescope", dn, "atpark")
            slewing,_= self._alpaca_get(addr, "telescope", dn, "slewing")
 
            def _fmt_ra(v):
                if v is None: return "—"
                h=int(v); m=int((v-h)*60); s=((v-h)*60-m)*60
                return f"{h:02d}h {m:02d}m {s:04.1f}s"
            def _fmt_dec(v):
                if v is None: return "—"
                sign="+" if v>=0 else "-"; v=abs(v)
                d=int(v); m=int((v-d)*60); s=((v-d)*60-m)*60
                return f"{sign}{d:02d}° {m:02d}′ {s:04.1f}″"
 
            status = ("PARKED" if parked else "SLEWING" if slewing else "TRACKING")
 
            def _upd():
                self._tel_ra.set(_fmt_ra(ra))
                self._tel_dec.set(_fmt_dec(dec))
                self._tel_alt.set(f"{alt:.2f}°" if alt is not None else "—")
                self._tel_az.set( f"{az:.2f}°"  if az  is not None else "—")
                self._tel_status.set(status, self._sc(status))
                self.tel_card.badge.set(status, self._sc(status))
                self._park_btn.set_enabled(not bool(parked))
 
            self.root.after(0, _upd)
            self.root.after(5000, lambda: threading.Thread(target=poll, daemon=True).start())
 
        threading.Thread(target=poll, daemon=True).start()
 
    def _start_cover_poll(self):
        def poll():
            cfg = DEVICE_CONFIGS["cover"]
            addr, dn = cfg["address"], cfg["device_number"]
            state_map = {0:"UNKNOWN",1:"CLOSED",2:"MOVING",3:"OPEN",4:"ERROR"}
            val, _ = self._alpaca_get(addr, "covercalibrator", dn, "coverstate")
            state  = state_map.get(val, "UNKNOWN")
            moving = (state == "MOVING")
 
            def _upd():
                self._cov_state.set(state, self._sc(state))
                self._cov_moving.set("YES" if moving else "NO",
                                     AMBER if moving else TEXT_SEC)
                self.cov_card.badge.set(state, self._sc(state))
 
            self.root.after(0, _upd)
            self.root.after(3000, lambda: threading.Thread(target=poll, daemon=True).start())
 
        threading.Thread(target=poll, daemon=True).start()
 
    def _start_dome_poll(self):
        def poll():
            try:
                cfg = DEVICE_CONFIGS["dome"]
                r = requests.get(
                    f"http://{cfg['host']}:{cfg['port']}/dome/state",
                    timeout=cfg.get("timeout_status", 2))
                data = r.json()
                left  = str(data.get("left",  "unknown")).upper()
                right = str(data.get("right", "unknown")).upper()
                closed = data.get("closed", False)
                left_moving  = left  in ("OPENING","CLOSING")
                right_moving = right in ("OPENING","CLOSING")
                moving = left_moving or right_moving
                overall = "CLOSED" if closed else ("MOVING" if moving else "OPEN")
 
                def _upd():
                    self._dome_left.set(left, self._sc(left))
                    self._dome_right.set(right, self._sc(right))
                    self._dome_overall.set(overall, self._sc(overall))
                    self.dome_card.badge.set(overall, self._sc(overall))
 
                self.root.after(0, _upd)
            except Exception:
                pass
            self.root.after(3000, lambda: threading.Thread(target=poll, daemon=True).start())
 
        threading.Thread(target=poll, daemon=True).start()
 
    def _start_rotator_poll(self):
        def poll():
            cfg = DEVICE_CONFIGS["rotator"]
            addr, dn = cfg["address"], cfg["device_number"]
            pos,    _ = self._alpaca_get(addr, "rotator", dn, "position")
            moving, _ = self._alpaca_get(addr, "rotator", dn, "ismoving")
 
            def _upd():
                self._rot_pos.set(f"{pos:.2f}°" if pos is not None else "—")
                self._rot_moving.set("YES" if moving else "NO",
                                     AMBER if moving else TEXT_SEC)
 
            self.root.after(0, _upd)
            self.root.after(5000, lambda: threading.Thread(target=poll, daemon=True).start())
 
        threading.Thread(target=poll, daemon=True).start()
 
    # ── Actions ───────────────────────────────────────────────────────────────
 
    def _park_telescope(self):
        self.log("INFO", "Parking telescope...")
        self._park_btn.set_enabled(False)
 
        def worker():
            try:
                cfg = DEVICE_CONFIGS["telescope"]
                addr, dn = cfg["address"], cfg["device_number"]
                if TELESCOPE_DRIVER:
                    drv = AlpacaTelescopeDriver()
                    if drv.connect(cfg):
                        drv.park(max_wait=120)
                        drv.disconnect()
                        self.log("OK", "Telescope parked")
                    else:
                        self.log("ERROR", "Park: could not connect to telescope")
                else:
                    requests.put(
                        f"http://{addr}/api/v1/telescope/{dn}/park",
                        json={"ClientID": 1, "ClientTransactionID": 1}, timeout=120)
                    self.log("OK", "Park command sent")
            except Exception as e:
                self.log("ERROR", f"Park failed: {e}")
 
        threading.Thread(target=worker, daemon=True).start()
 
    def _abort_slew(self):
        self.log("WARN", "Sending abort slew command...")
        def worker():
            try:
                cfg = DEVICE_CONFIGS["telescope"]
                addr, dn = cfg["address"], cfg["device_number"]
                requests.put(
                    f"http://{addr}/api/v1/telescope/{dn}/abortslew",
                    json={"ClientID": 1, "ClientTransactionID": 1}, timeout=10)
                self.log("OK", "Abort slew sent")
            except Exception as e:
                self.log("ERROR", f"Abort failed: {e}")
        threading.Thread(target=worker, daemon=True).start()
 
    def _covers_action(self, action: str):
        label = "Opening" if action == "open" else "Closing"
        self.log("INFO", f"{label} covers...")
        self._cov_open_btn.set_enabled(False)
        self._cov_close_btn.set_enabled(False)
 
        def worker():
            try:
                cfg = DEVICE_CONFIGS["cover"]
                addr, dn = cfg["address"], cfg["device_number"]
                if COVER_DRIVER:
                    drv = AlpacaCoverDriver()
                    if drv.connect(cfg):
                        if action == "open":  drv.open_cover()
                        else:                 drv.close_cover()
                        drv.disconnect()
                        self.log("OK", f"Covers {action}ed")
                    else:
                        self.log("ERROR", "Cover: connection failed")
                else:
                    endpoint = "opencover" if action == "open" else "closecover"
                    requests.put(
                        f"http://{addr}/api/v1/covercalibrator/{dn}/{endpoint}",
                        json={"ClientID": 1, "ClientTransactionID": 1},
                        timeout=cfg.get("operation_timeout", 30))
                    self.log("OK", f"Cover {action} command sent")
            except Exception as e:
                self.log("ERROR", f"Cover {action} failed: {e}")
            finally:
                self.root.after(0, lambda: self._cov_open_btn.set_enabled(True))
                self.root.after(0, lambda: self._cov_close_btn.set_enabled(True))
 
        threading.Thread(target=worker, daemon=True).start()
 
    def _dome_action(self, action: str):
        label = "Opening" if action == "open" else "Closing"
        self.log("INFO", f"{label} dome panels...")
        for b in (self._dome_open_btn, self._dome_close_btn):
            b.set_enabled(False)
 
        def worker():
            try:
                cfg = DEVICE_CONFIGS["dome"]
                if DOME_DRIVER and self.dome_driver:
                    ok = (self.dome_driver.open() if action == "open"
                          else self.dome_driver.close())
                    self.log("OK" if ok else "ERROR",
                             f"Dome {action}: {'success' if ok else 'failed'}")
                else:
                    endpoint = "/dome/true" if action == "open" else "/dome/false"
                    requests.put(
                        f"http://{cfg['host']}:{cfg['port']}{endpoint}",
                        timeout=cfg.get("timeout_move", 75))
                    self.log("OK", f"Dome {action} command sent")
            except Exception as e:
                self.log("ERROR", f"Dome {action} failed: {e}")
            finally:
                self.root.after(0, lambda: self._dome_open_btn.set_enabled(True))
                self.root.after(0, lambda: self._dome_close_btn.set_enabled(True))
 
        threading.Thread(target=worker, daemon=True).start()
 
    def _dome_abort(self):
        self.log("WARN", "Sending dome abort...")
        def worker():
            try:
                cfg = DEVICE_CONFIGS["dome"]
                if DOME_DRIVER and self.dome_driver:
                    self.dome_driver.abort()
                else:
                    requests.put(
                        f"http://{cfg['host']}:{cfg['port']}/dome/abort",
                        timeout=cfg.get("timeout_abort", 20))
                self.log("OK", "Dome abort sent")
            except Exception as e:
                self.log("ERROR", f"Dome abort failed: {e}")
        threading.Thread(target=worker, daemon=True).start()
 
    # ── Night modal ───────────────────────────────────────────────────────────
 
    def _night_modal(self, mode: str):
        NightModal(self.root, mode, self._execute_night)
 
    def _execute_night(self, mode: str, opts: Dict[str, bool]):
        label = "START NIGHT" if mode == "start" else "END NIGHT"
        self.log("SYS", f"▶ {label} sequence initiated")
 
        def worker():
            if mode == "start":
                if opts.get("dome"):    self._dome_action("open");    time.sleep(5)
                if opts.get("covers"):  self._covers_action("open");  time.sleep(5)
                if opts.get("motors"):
                    self.log("INFO", "Telescope motors enable — manual via Autoslew if needed")
            else:
                if opts.get("park"):    self._park_telescope();       time.sleep(10)
                if opts.get("covers"):  self._covers_action("close"); time.sleep(5)
                if opts.get("dome"):    self._dome_action("close");   time.sleep(5)
            self.log("OK", f"▶ {label} complete")
 
        threading.Thread(target=worker, daemon=True).start()
 
    # ── Run ───────────────────────────────────────────────────────────────────
 
    def run(self):
        self.root.mainloop()
 
 
