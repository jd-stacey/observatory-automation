class DeviceCard(tk.Frame):
    """
    A bordered card containing:
      [icon box 80×80] | [status + info rows] | [action buttons]
    All cards are the same fixed height so status columns line up.
    """
    CARD_HEIGHT = 110
    ICON_SIZE   = 80    # fixed square for icon area
 
    def __init__(self, parent, title: str, draw_fn, **kw):
        super().__init__(parent, bg=PANEL,
                         highlightbackground=BORDER, highlightthickness=1, **kw)
        self._draw_fn = draw_fn
        self._title   = title
        self._conn    = False
 
        # ── Left: icon box (fixed size) ────────────────────────────────────
        icon_frame = tk.Frame(self, bg=SURFACE, width=self.ICON_SIZE,
                              height=self.CARD_HEIGHT)
        icon_frame.pack(side="left", fill="y")
        icon_frame.pack_propagate(False)
 
        self.icon_canvas = tk.Canvas(icon_frame, width=self.ICON_SIZE,
                                     height=self.ICON_SIZE - 22,
                                     bg=SURFACE, highlightthickness=0)
        self.icon_canvas.pack(pady=(8, 0))
 
        tk.Label(icon_frame, text=title, font=("Consolas", 7, "bold"),
                 fg=TEXT_SEC, bg=SURFACE, letterSpacing=2).pack()
 
        lamp_row = tk.Frame(icon_frame, bg=SURFACE)
        lamp_row.pack(pady=3)
        self.lamp_a = Lamp(lamp_row, bg=SURFACE)
        self.lamp_a.pack(side="left", padx=3)
        self.lamp_b = Lamp(lamp_row, bg=SURFACE)
        self.lamp_b.pack(side="left", padx=3)
 
        # ── Thin vertical separator ────────────────────────────────────────
        sep = tk.Frame(self, bg=BORDER, width=1)
        sep.pack(side="left", fill="y")
 
        # ── Middle: info area ──────────────────────────────────────────────
        self.info_frame = tk.Frame(self, bg=PANEL)
        self.info_frame.pack(side="left", fill="both", expand=True, padx=10, pady=8)
 
        self.badge = StatusBadge(self.info_frame)
        self.badge.pack(anchor="w", pady=(0, 5))
 
        self.rows_frame = tk.Frame(self.info_frame, bg=PANEL)
        self.rows_frame.pack(fill="both", expand=True)
 
        # ── Right: action buttons ──────────────────────────────────────────
        self.btn_frame = tk.Frame(self, bg=PANEL)
        self.btn_frame.pack(side="right", fill="y", padx=8, pady=8)
 
        # Draw initial (dimmed) icon
        self._redraw_icon(connected=False)
 
    def _redraw_icon(self, connected: bool):
        color = TEXT_PRI if connected else "#3A4555"
        cx = self.ICON_SIZE // 2
        cy = (self.ICON_SIZE - 22) // 2
        self._draw_fn(self.icon_canvas, cx, cy, color)
 
    def add_info_row(self, label: str) -> InfoBlock:
        row = InfoBlock(self.rows_frame, label)
        row.pack(fill="x", pady=1)
        return row
 
    def add_button(self, text: str, command=None, danger=False) -> SmallButton:
        btn = SmallButton(self.btn_frame, text, command=command, danger=danger)
        btn.pack(fill="x", pady=2)
        return btn
 
    def set_lamp(self, state: str):
        self.lamp_a.set_state(state)
        self.lamp_b.set_state(state)
        self._redraw_icon(state == "connected")
        self._conn = (state == "connected")
 
    def set_lamp_a(self, state): self.lamp_a.set_state(state)
    def set_lamp_b(self, state): self.lamp_b.set_state(state)
 
    def connect_callback(self, cb):
        self.lamp_a._cb = cb
        self.lamp_a.bind("<Button-1>", lambda e: cb())
        self.lamp_b._cb = cb
        self.lamp_b.bind("<Button-1>", lambda e: cb())
 
 
