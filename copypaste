class Lamp(tk.Canvas):
    """Small circular status lamp. Click to trigger callback."""
    def __init__(self, parent, callback=None, **kw):
        super().__init__(parent, width=11, height=11, bg=PANEL,
                         highlightthickness=0, cursor="hand2", **kw)
        self._cb = callback
        self._state = "off"
        self._anim_id = None
        self._bright = True
        self._draw()
        if callback:
            self.bind("<Button-1>", lambda e: callback())
 
    def _draw(self):
        self.delete("all")
        colors = {"connected": GREEN, "disconnected": RED, "connecting": AMBER, "off": INACTIVE}
        c = colors.get(self._state, INACTIVE)
        if self._state != "off":
            # glow ring
            self.create_oval(1, 1, 10, 10, fill=c, outline=c)
        else:
            self.create_oval(1, 1, 10, 10, fill=INACTIVE, outline=BORDER)
 
    def set_state(self, state):
        self._state = state
        if self._anim_id:
            self.after_cancel(self._anim_id)
            self._anim_id = None
        if state == "connecting":
            self._pulse()
        else:
            self._draw()
 
    def _pulse(self):
        self._bright = not self._bright
        self.delete("all")
        c = AMBER if self._bright else BORDER
        self.create_oval(1, 1, 10, 10, fill=c, outline=c)
        self._anim_id = self.after(500, self._pulse)
 
 
class SmallButton(tk.Frame):
    """Compact action button matching the futuristic aesthetic."""
    def __init__(self, parent, text, command=None, danger=False, **kw):
        super().__init__(parent, bg=PANEL, **kw)
        border_c = RED if danger else BORDER
        self._danger = danger
        self._cmd = command
        self._btn = tk.Label(
            self, text=text,
            font=("Consolas", 8, "bold"),
            fg=RED if danger else TEXT_SEC,
            bg=PANEL,
            padx=8, pady=3,
            relief="flat",
            cursor="hand2" if command else "arrow",
        )
        self._btn.pack()
        self.config(highlightbackground=border_c, highlightthickness=1, highlightcolor=border_c)
        if command:
            self._btn.bind("<Enter>", self._on_enter)
            self._btn.bind("<Leave>", self._on_leave)
            self._btn.bind("<Button-1>", lambda e: command() if self._enabled else None)
        self._enabled = True
 
    def _on_enter(self, e):
        if self._enabled:
            self._btn.config(fg=ACCENT, bg="#1E2A38")
            self.config(highlightbackground=ACCENT)
 
    def _on_leave(self, e):
        self._btn.config(fg=RED if self._danger else TEXT_SEC, bg=PANEL)
        self.config(highlightbackground=RED if self._danger else BORDER)
 
    def set_enabled(self, enabled: bool):
        self._enabled = enabled
        self._btn.config(
            fg=(RED if self._danger else TEXT_SEC) if enabled else "#3A4555",
            cursor="hand2" if enabled else "arrow"
        )
 
 
class InfoBlock(tk.Frame):
    """Label/value pair row."""
    def __init__(self, parent, label, **kw):
        super().__init__(parent, bg=PANEL, **kw)
        tk.Label(self, text=label.upper(), font=("Consolas", 7, "bold"),
                 fg=TEXT_SEC, bg=PANEL, anchor="w").pack(side="left")
        self._val = tk.Label(self, text="—", font=("Consolas", 9),
                             fg=TEXT_PRI, bg=PANEL, anchor="e")
        self._val.pack(side="right")
 
    def set(self, text, color=None):
        self._val.config(text=text, fg=color or TEXT_PRI)
 
 
