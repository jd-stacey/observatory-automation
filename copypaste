def ensure_closed(driver: DomeDriver):
    """Always attempt to close the dome at the end of testing."""
    section("FINAL: ENSURING DOME IS CLOSED")
    print("\n  Checking current state...")
    print_state(driver)

    if driver.is_closed():
        print("\n  Dome is already closed. Nothing to do.")
        return

    print("\n  Dome is not fully closed. Sending close command...")
    try:
        success = driver._send_command("/dome/false")
        if not success:
            print("  WARNING: Close command returned failure - check dome manually!")
            return
        print("  Waiting for dome to close...")
        reached = wait_with_progress(
            driver,
            target_left=DomeDriver.STATE_CLOSED,
            target_right=DomeDriver.STATE_CLOSED,
            timeout=driver.timeout_move
        )
        if reached:
            print("  Dome confirmed closed.")
        else:
            print("  WARNING: Dome did not confirm closed state - check dome manually!")
    except Exception as e:
        print(f"  ERROR during close: {e}")
        print("  WARNING: Check dome state manually!")


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
def main():

    # Load devices.yaml
    config_path = Path(__file__).parent.parent.parent / 'config' / 'devices.yaml'
    if not config_path.exists():
        print(f"ERROR: devices.yaml not found at {config_path}")
        sys.exit(1)

    with open(config_path) as f:
        devices = yaml.safe_load(f)

    if TEST_DOME_KEY not in devices:
        print(f"ERROR: '{TEST_DOME_KEY}' not found in devices.yaml")
        sys.exit(1)

    dome_config = devices[TEST_DOME_KEY]
    dome_id     = dome_config.get('dome_id', TEST_DOME_KEY)

    # Title
    separator("=", 60)
    print(f"  MT KENT OBSERVATORY - DOME ACTION TEST SCRIPT")
    print(f"  {time.strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"  Target dome : {dome_id}  ({TEST_DOME_KEY})")
    separator("=", 60)
    print()
    print("  !! This script commands REAL hardware !!")
    print("  !! Ensure the dome area is clear before proceeding !!")
    print("  !! The dome will always be closed at the end !!")

    if not ask_proceed("\nReady to begin? Start with status checks only"):
        print("\n  Aborted by user.")
        sys.exit(0)

    # Connect
    section("CONNECTING")
    print(f"\n  Connecting to {dome_id}...")
    driver = DomeDriver()
    connected = driver.connect(dome_config)
    if not connected:
        print(f"  ERROR: Could not connect to {dome_id}. Exiting.")
        sys.exit(1)
    print(f"  Connected to {dome_id}")

    # Track results
    results = {}

    # --- Status checks (always run) ---
    results['status'] = test_status_checks(driver)

    # --- Movement tests ---
    section("MOVEMENT TESTS")
    print("\n  Status checks complete.")
    print("  The following sections will command physical dome movement.")
    print("  You will be prompted before each test.")

    if not ask_proceed("Proceed to movement tests?"):
        print("\n  Movement tests skipped by user.")
    else:
        results['left_panel']  = test_left_panel(driver)
        results['right_panel'] = test_right_panel(driver)
        results['full_dome']   = test_full_dome(driver)

    # --- Always close at end ---
    ensure_closed(driver)

    # --- Disconnect ---
    section("DISCONNECTING")
    driver.disconnect()
    print("  Disconnected.")

    # --- Summary ---
    section("TEST SUMMARY")
    print()
    all_passed = True
    for test_name, passed in results.items():
        status = "PASSED" if passed else "FAILED"
        print(f"  {test_name:<20} : {status}")
        if not passed:
            all_passed = False
    print()
    separator("=")
    if all_passed:
        print("  ALL TESTS PASSED")
    else:
        print("  SOME TESTS FAILED - review output above")
    separator("=")
    print()

if __name__ == "__main__":
    main()
